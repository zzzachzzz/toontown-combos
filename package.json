{
  "name": "toontown-combos",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build && cp ./404.html ./dist/ && touch ./dist/.nojekyll",
    "serve": "vite preview",
    "test": "vitest run",
    "test-watch": "vitest watch",
    "publish": "npm run build && gh-pages --dist dist",
    "ci": "npm run type-check && npm run test",
    "cicd": "npm run _confirmprompt && npm run ci && npm run publish",
    "_confirmprompt": "echo 'Type DEPLOY to confirm: ' && read confirm && [ \"$confirm\" = 'DEPLOY' ] || { echo 'Aborted'; exit 1; }",
    "gags-cli": "tsx ./src/gags-cli.ts",
    "cache-codegen": "tsx ./src/findCombo-cache-codegen.ts",
    "type-check": "tsc --noEmit --skipLibCheck"
  },
  "license": "MIT",
  "devDependencies": {
    "gh-pages": "^3.1.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.4",
    "@types/testing-library__jest-dom": "^6.0.0",
    "jsdom": "^26.1.0",
    "solid-devtools": "^0.34.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vite-plugin-solid": "3.0.0-next.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.4",
    "solid-js": "2.0.0-beta.2"
  }
}
